# Ellucian Banner Student credentials
ELLUCIAN_BANNER_URL=https://your-university.edu/ssomanager/c/SSB
ELLUCIAN_BANNER_USERNAME=your-username-or-email
ELLUCIAN_BANNER_PASSWORD=your-password

# MFA Configuration (if required)
# MFA_SECRET=your-base32-totp-secret
# MFA_TYPE=totp  # Options: totp | duo_push | sms

# Session persistence
SESSION_PATH=./session.json
SESSION_MAX_AGE_HOURS=8

# Browser behavior
HEADLESS=true  # Set to false to see the browser window

# AnchorBrowser (recommended for production)
# Get your free API key at: https://anchorbrowser.io
# ANCHORBROWSER_API_KEY=your-api-key
